# Runstamp mobile — public runtime config.
#
# Copy this file to apps/mobile/.env and fill in real values.
# `EXPO_PUBLIC_*` env vars are inlined into the JS bundle, so treat them as
# public. Anything sensitive (client SECRETS, signing keys) MUST stay out of
# this file — use EAS Secrets for build-time secrets and the backend
# (apps/api) for OAuth client secrets / DB creds.

# Public Strava OAuth client id (the secret stays on the backend).
EXPO_PUBLIC_STRAVA_CLIENT_ID=

# Base URL for the Runstamp API. Defaults to http://localhost:8080 if unset.
# Production points at api.runstamp.gilla.fun via the Cloudflared tunnel.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────
# Firebase
# ─────────────────────────────────────────────────────────────────────────────
# Firebase is wired via @react-native-firebase/* with the native plist + json.
# There are NO EXPO_PUBLIC_FIREBASE_* env vars — the config plugin picks up:
#
#   apps/mobile/GoogleService-Info.plist       (iOS)
#   apps/mobile/google-services.json           (Android)
#
# Both are gitignored. Download them from the Firebase Console:
#   Project Settings → Your apps → iOS / Android → "Download config file".
# For CI, upload them as EAS Secrets and override the paths via
# GOOGLE_SERVICES_INFOPLIST / GOOGLE_SERVICES_JSON env vars at build time.

# Google Sign-In — Web OAuth client id.
# Native Google Sign-In on Firebase needs the WEB client id (not the iOS one)
# to produce an idToken that `auth.GoogleAuthProvider.credential` accepts.
# Find it in the Firebase Console → Project Settings → Your apps → Web app,
# OR Google Cloud Console → APIs & Services → Credentials → Web client.
# This is PUBLIC.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
