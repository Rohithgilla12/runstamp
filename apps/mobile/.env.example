# Runstamp mobile — public runtime config.
#
# Copy this file to apps/mobile/.env and fill in real values.
# `EXPO_PUBLIC_*` env vars are inlined into the JS bundle, so treat them as
# public. Anything sensitive (client SECRETS, signing keys) MUST stay out of
# this file — use EAS Secrets for build-time secrets and the backend
# (apps/api) for OAuth client secrets / DB creds.

# Public Strava OAuth client id (the secret stays on the backend).
EXPO_PUBLIC_STRAVA_CLIENT_ID=

# Base URL for the Runstamp API. Defaults to http://localhost:8080 if unset.
# Production points at api.runstamp.gilla.fun via the Cloudflared tunnel.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Firebase project config — all public values, safe to commit to the bundle.
# Find these in the Firebase Console → Project Settings → Your apps → Web app.
# URL: https://console.firebase.google.com/project/<project-id>/settings/general
#
# IMPORTANT: these values are PUBLIC. The Firebase security model relies on
# Security Rules and Firebase Auth on the backend — the config below is not a
# secret and intentionally ships inside the app binary.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Google Sign-In — iOS OAuth 2.0 client ID.
# Create it in Google Cloud Console → APIs & Services → Credentials →
# OAuth 2.0 Client IDs → iOS (bundle: fun.gilla.runstamp).
# URL: https://console.cloud.google.com/apis/credentials
#
# This is PUBLIC — it identifies the app to Google but cannot be used to
# impersonate the app without possession of the device. Secrets stay on the
# backend (Google does not use a client secret for native iOS flows).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
