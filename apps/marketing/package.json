{
  "name": "@runstamp/marketing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "remotion studio",
    "render:vertical": "remotion render LaunchStory out/launch-story.mp4 --concurrency=1",
    "render:wide": "remotion render LaunchPost out/launch-post.mp4 --concurrency=1",
    "render:all": "pnpm render:vertical && pnpm render:wide",
    "render:appstore": "node scripts/render-appstore.mjs",
    "render:social-cut": "mkdir -p out/appstore && ffmpeg -y -i out/launch-story.mp4 -t 29.9 -c:v libx264 -pix_fmt yuv420p -movflags +faststart -c:a aac out/appstore/social-cut-1080x1920.mp4",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.474",
    "@remotion/google-fonts": "4.0.474",
    "@remotion/transitions": "^4.0.474",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "remotion": "4.0.474",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.11",
    "typescript": "5.8.3"
  }
}
