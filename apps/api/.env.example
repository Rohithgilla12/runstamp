# Runstamp API — server-side configuration.
#
# Copy this file to apps/api/.env and fill in real values for local dev.
# Production values live in your VPS systemd unit / EAS Secrets / wherever —
# never commit real secrets.

# Server
RUNSTAMP_PORT=8080
RUNSTAMP_ENV=development
# Comma-separated list of origins allowed for CORS. Includes Metro dev server
# and Expo deep-link scheme.
RUNSTAMP_ALLOWED_ORIGINS=http://localhost:8081,exp://*

# Strava (https://www.strava.com/settings/api). The mobile app holds the
# client ID via EXPO_PUBLIC_STRAVA_CLIENT_ID; this server holds the secret.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Random opaque string. You provide the same value when subscribing the
# webhook (the GET handshake echoes it back to verify ownership).
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Database (Postgres 16 + PostGIS)
DATABASE_URL=postgres://runstamp:runstamp@localhost:5432/runstamp?sslmode=disable

# Message queue / cache
REDIS_URL=redis://localhost:6379/0

# Token encryption key — 32 random bytes as a 64-char hex string.
# Generate a fresh key with: openssl rand -hex 32
# Leave blank in local dev to use the insecure all-zeros dev key (boot will warn).
# REQUIRED in production (RUNSTAMP_ENV=production will refuse to start without it).
RUNSTAMP_TOKEN_ENC_KEY=
