---
interface Props {
  source: "landing-hero" | "landing-footer-cta";
  id: string;
}

const { source, id } = Astro.props;

const formId = `waitlist-form-${id}`;
const emailId = `waitlist-email-${id}`;
const honeyId = `company-${id}`;
---

<div class="waitlist-widget" data-source={source} data-form-id={formId}>
  <form
    id={formId}
    class="wl-form"
    aria-label="Join the Runstamp waitlist"
    novalidate
  >
    <!-- Honeypot: bots fill this, humans don't see it -->
    <input
      id={honeyId}
      name="company"
      type="text"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      class="wl-honey"
    />

    <label for={emailId} class="visually-hidden">Email address</label>
    <div class="wl-row">
      <input
        id={emailId}
        name="email"
        type="email"
        placeholder="you@example.com"
        required
        autocomplete="email"
        class="wl-input"
        aria-describedby={`${formId}-note`}
      />
      <button type="submit" class="wl-btn" aria-live="polite">
        <span class="wl-btn-idle">Get early access</span>
        <span class="wl-btn-loading" aria-hidden="true">Stamping...</span>
      </button>
    </div>
    <p id={`${formId}-note`} class="wl-note eyebrow">
      One message when we launch. No newsletters.
    </p>
    <p class="wl-error" role="alert" aria-live="assertive"></p>
  </form>

  <!-- Success state — hidden until form succeeds -->
  <div class="wl-success" aria-live="polite" hidden>
    <svg class="wl-postmark" viewBox="0 0 120 120" aria-hidden="true" width="120" height="120">
      <circle cx="60" cy="60" r="56" fill="none" stroke="currentColor" stroke-width="1.8" stroke-dasharray="3 3" opacity="0.6"></circle>
      <circle cx="60" cy="60" r="44" fill="none" stroke="currentColor" stroke-width="1" opacity="0.4"></circle>
      <line x1="22" y1="55" x2="98" y2="55" stroke="currentColor" stroke-width="1.4" opacity="0.5"></line>
      <line x1="22" y1="63" x2="98" y2="63" stroke="currentColor" stroke-width="1.4" opacity="0.5"></line>
      <line x1="22" y1="71" x2="98" y2="71" stroke="currentColor" stroke-width="1.4" opacity="0.5"></line>
      <!-- Checkmark in the centre band -->
      <polyline points="42,63 53,74 78,48" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></polyline>
    </svg>
    <p class="wl-success-headline">On the list.</p>
    <p class="wl-success-sub">Talk soon — when the door opens.</p>
  </div>
</div>

<style>
  .waitlist-widget { width: 100%; }

  .wl-honey {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
    tabindex: -1;
  }

  .wl-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  @media (min-width: 480px) {
    .wl-row { flex-direction: row; }
  }

  .wl-input {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 0.75rem 1rem;
    background: var(--input-bg, rgba(243, 237, 226, 0.08));
    border: 1px solid var(--input-border, rgba(243, 237, 226, 0.2));
    border-radius: 2px;
    color: var(--input-color, var(--paper));
    outline: none;
    transition: border-color 0.15s ease;
  }

  .wl-input::placeholder {
    color: var(--input-placeholder, rgba(243, 237, 226, 0.3));
  }

  .wl-input:focus {
    border-color: var(--input-focus, rgba(243, 237, 226, 0.5));
  }

  .wl-input[aria-invalid="true"] {
    border-color: var(--error);
  }

  .wl-btn {
    position: relative;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.75rem 1.375rem;
    background: var(--solar);
    color: #f3ede2;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.15s ease, opacity 0.15s ease;
    overflow: hidden;
  }

  .wl-btn:hover:not(:disabled) {
    background: var(--solar-deep);
  }

  .wl-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .wl-btn-idle,
  .wl-btn-loading {
    display: block;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .wl-btn-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(4px);
  }

  .wl-btn[data-loading] .wl-btn-idle {
    opacity: 0;
    transform: translateY(-4px);
  }

  .wl-btn[data-loading] .wl-btn-loading {
    opacity: 1;
    transform: translateY(0);
  }

  .wl-note {
    color: var(--note-color, rgba(243, 237, 226, 0.32));
    margin-bottom: var(--space-2);
  }

  .wl-error {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--error);
    min-height: 1.2em;
    letter-spacing: 0.04em;
  }

  .wl-success {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    padding-block: var(--space-4);
    color: var(--success-color, var(--paper));
  }

  .wl-postmark {
    color: var(--solar);
    opacity: 0.9;
  }

  .wl-success-headline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--success-color, var(--paper));
    line-height: 1;
  }

  .wl-success-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--success-sub-color, rgba(243, 237, 226, 0.5));
  }
</style>

<script>
  document.querySelectorAll<HTMLDivElement>(".waitlist-widget").forEach((widget) => {
    const source = widget.dataset.source ?? "landing-hero";
    const formId = widget.dataset.formId ?? "";
    const form = widget.querySelector<HTMLFormElement>(`#${formId}`);
    const btn = form?.querySelector<HTMLButtonElement>(".wl-btn");
    const emailInput = form?.querySelector<HTMLInputElement>('[type="email"]');
    const honeyInput = form?.querySelector<HTMLInputElement>('[name="company"]');
    const errorEl = form?.querySelector<HTMLParagraphElement>(".wl-error");
    const successEl = widget.querySelector<HTMLDivElement>(".wl-success");

    if (!form || !btn || !emailInput || !errorEl || !successEl) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Honeypot check — bots fill the hidden field; drop silently
      if (honeyInput?.value) {
        form.hidden = true;
        successEl.hidden = false;
        return;
      }

      const email = emailInput.value.trim();
      if (!email) {
        emailInput.setAttribute("aria-invalid", "true");
        errorEl.textContent = "an email address is required.";
        emailInput.focus();
        return;
      }

      btn.setAttribute("data-loading", "");
      btn.disabled = true;
      emailInput.setAttribute("aria-invalid", "false");
      errorEl.textContent = "";

      try {
        const res = await fetch("https://runstamp-api.gilla.fun/v1/waitlist", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, source }),
        });

        if (res.status === 201) {
          form.hidden = true;
          successEl.hidden = false;
          return;
        }

        if (res.status === 429) {
          errorEl.textContent = "rate-limited — try again in a minute.";
          return;
        }

        if (res.status === 400) {
          emailInput.setAttribute("aria-invalid", "true");
          errorEl.textContent = "that doesn't look like a valid email.";
          emailInput.focus();
          return;
        }

        errorEl.textContent = "couldn't reach the server — try again shortly.";
      } catch {
        errorEl.textContent = "couldn't reach the server — try again shortly.";
      } finally {
        btn.removeAttribute("data-loading");
        btn.disabled = false;
      }
    });
  });
</script>
