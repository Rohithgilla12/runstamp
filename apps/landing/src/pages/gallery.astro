---
import Base from "../layouts/Base.astro";

const sunRayAngles = Array.from({ length: 8 }, (_, i) => (i * Math.PI * 2) / 8);
const perfSide = (count: number) => Array.from({ length: count }, (_, i) => i);
const p9L = perfSide(9);
const p9R = perfSide(9);
const p7T = perfSide(7);
const p7B = perfSide(7);
const p4 = perfSide(4);

// Airmail stripes helper
const stripes = Array.from({ length: 22 }, (_, i) => i);

// Customs form rows variants
const formRowsA = [
  { label: "Distance Declared", value: "21.1 KM" },
  { label: "Pace Declared",     value: "5:12 / KM" },
  { label: "Time Declared",     value: "1:49:43" },
  { label: "Elevation Gain",    value: "312 M" },
  { label: "Purpose of Visit",  value: "Race — Competition" },
  { label: "City of Origin",    value: "Tokyo" },
  { label: "Country",           value: "Japan" },
];

const formRowsB = [
  { label: "Distance Declared", value: "32.0 KM" },
  { label: "Pace Declared",     value: "4:58 / KM" },
  { label: "Time Declared",     value: "2:39:14" },
  { label: "Elevation Gain",    value: "86 M" },
  { label: "Purpose of Visit",  value: "Long Run" },
  { label: "City of Origin",    value: "Bangalore" },
  { label: "Country",           value: "India" },
];

interface Card {
  id: string;
  template: string;
  caption: string;
}

const cards: Card[] = [
  { id: "card-postage-tokyo",    template: "postage-tokyo",    caption: "Imperial Palace loop — Tokyo, 10 km." },
  { id: "card-postmark-blr",     template: "postmark-blr",     caption: "Cubbon Park long run — Bangalore, 24 km." },
  { id: "card-customs-tokyo",    template: "customs-tokyo",    caption: "Shinjuku half — Tokyo. Sub-3:45 attempt." },
  { id: "card-passport-london",  template: "passport-london",  caption: "Hampstead Heath trails — London, 11.2 km." },
  { id: "card-postage-goa",      template: "postage-goa",      caption: "Vagator beach run — Goa. 9.4 km." },
  { id: "card-postmark-mumbai",  template: "postmark-mumbai",  caption: "Marine Drive sunrise — Mumbai, 12.1 km." },
  { id: "card-customs-blr",      template: "customs-blr",      caption: "Sankey Tank loops — Bangalore. Easy day." },
  { id: "card-postage-london",   template: "postage-london",   caption: "Autumn morning in London — 11 km." },
  { id: "card-postmark-tokyo2",  template: "postmark-tokyo2",  caption: "Late evening tempo — Tokyo, 9 km." },
  { id: "card-passport-blr",     template: "passport-blr",     caption: "400m intervals — Kanteerava Stadium." },
  { id: "card-customs-singapore", template: "customs-singapore", caption: "Gardens by the Bay dawn — Singapore." },
  { id: "card-postage-paris",    template: "postage-paris",    caption: "Seine riverside — Paris, 8.5 km." },
];
---

<Base
  title="Share Card Gallery — Runstamp"
  description="12 sample Runstamp share cards across Postage, Postmark, Customs, and Passport templates. See what the app produces."
>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="wordmark" aria-label="Runstamp home">
        <svg width="20" height="20" viewBox="0 0 28 28" aria-hidden="true">
          <circle cx="14" cy="14" r="5.5" fill="var(--solar)"></circle>
          {sunRayAngles.map((a) => (
            <line
              x1={(14 + Math.cos(a) * 8.5).toFixed(2)}
              y1={(14 + Math.sin(a) * 8.5).toFixed(2)}
              x2={(14 + Math.cos(a) * 12).toFixed(2)}
              y2={(14 + Math.sin(a) * 12).toFixed(2)}
              stroke="var(--solar)"
              stroke-width="1.8"
              stroke-linecap="round"
            />
          ))}
        </svg>
        <span>Runstamp</span>
      </a>
      <nav aria-label="Site navigation">
        <ul class="nav-links">
          <li><a href="/" class="nav-link">Home</a></li>
          <li><a href="/stamps" class="nav-link">Stamps</a></li>
          <li><a href="/#waitlist" class="nav-cta">Join waitlist</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">Share card gallery</p>
        <h1 class="page-headline">What the app produces.</h1>
        <p class="page-sub">
          Hand-crafted mockups of the four template families at launch. Every card
          is built from real run data. Click any card to see it full-size.
        </p>
        <p class="gallery-note eyebrow">4 templates · 12 sample cards · real run data</p>
      </div>
    </section>

    <section class="gallery-section" aria-labelledby="gallery-label">
      <h2 id="gallery-label" class="visually-hidden">Share card gallery</h2>
      <div class="container">
        <ul class="gallery-grid" role="list">

          <!-- 1: Postage — Tokyo Imperial Palace loop (dark, portrait) -->
          <li class="gallery-item">
            <button class="gallery-trigger" aria-haspopup="dialog" aria-controls="modal-card-postage-tokyo" data-modal="modal-card-postage-tokyo" type="button">
              <figure class="card-figure" aria-label={cards[0].caption}>
                <div class="card-frame">
                  <svg viewBox="0 0 280 370" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="280" height="370" fill="#f3ede2"></rect>
                    <rect x="16" y="16" width="248" height="338" fill="#14110d"></rect>
                    {Array.from({ length: 6 }, (_, row) => Array.from({ length: 11 }, (_, col) => (
                      <circle cx={30 + col * 22} cy={90 + row * 26} r={0.6 + ((row + col) % 3) * 0.18} fill="rgba(243,237,226,0.05)"></circle>
                    )))}
                    <path d="M50 285 Q90 250 125 268 Q158 284 182 240 Q206 198 240 212"
                      stroke="#e85d2f" stroke-width="2.3" fill="none" stroke-linecap="round" opacity="0.88" class="animated-route"></path>
                    <text x="30" y="42" font-family="monospace" font-size="7.5" letter-spacing="3.2" fill="rgba(243,237,226,0.48)">JAPAN</text>
                    <text x="30" y="72" font-family="Georgia, serif" font-style="italic" font-size="30" fill="#f3ede2">Tokyo</text>
                    <rect x="192" y="28" width="58" height="18" fill="none" stroke="rgba(243,237,226,0.28)" stroke-width="1" rx="2"></rect>
                    <text x="221" y="41" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(243,237,226,0.48)">NO. A0009</text>
                    <text x="30" y="310" font-family="monospace" font-size="50" font-weight="500" fill="#f3ede2" letter-spacing="-2.5">10.0</text>
                    <text x="30" y="328" font-family="monospace" font-size="8" fill="rgba(243,237,226,0.42)" letter-spacing="2.8">KILOMETRES</text>
                    <text x="250" y="300" text-anchor="end" font-family="monospace" font-size="13.5" fill="rgba(243,237,226,0.78)">4:48/km</text>
                    <text x="250" y="318" text-anchor="end" font-family="monospace" font-size="10" fill="rgba(243,237,226,0.46)">48:00</text>
                    <text x="250" y="334" text-anchor="end" font-family="monospace" font-size="7.5" fill="rgba(243,237,226,0.28)" letter-spacing="0.6">2026 · JAN · 22</text>
                    <circle cx="210" cy="178" r="36" fill="none" stroke="rgba(243,237,226,0.08)" stroke-width="1.2" stroke-dasharray="2 3"></circle>
                    {p9L.map((i) => <circle cx="16" cy={32 + i * 36} r="9" fill="#f3ede2" />)}
                    {p9R.map((i) => <circle cx="264" cy={32 + i * 36} r="9" fill="#f3ede2" />)}
                    {p7T.map((i) => <circle cx={36 + i * 34} cy="16" r="9" fill="#f3ede2" />)}
                    {p7B.map((i) => <circle cx={36 + i * 34} cy="354" r="9" fill="#f3ede2" />)}
                  </svg>
                </div>
                <figcaption class="card-cap eyebrow">{cards[0].caption}</figcaption>
              </figure>
            </button>
          </li>

          <!-- 2: Postmark — Bangalore Cubbon Park 24K -->
          <li class="gallery-item">
            <button class="gallery-trigger" aria-haspopup="dialog" aria-controls="modal-card-postmark-blr" data-modal="modal-card-postmark-blr" type="button">
              <figure class="card-figure" aria-label={cards[1].caption}>
                <div class="card-frame">
                  <svg viewBox="0 0 280 370" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="280" height="370" fill="#14110d"></rect>
                    <path d="M30 320 Q70 260 108 282 Q148 305 180 248 Q212 192 252 218"
                      stroke="#e85d2f" stroke-width="3.5" fill="none" stroke-linecap="round" opacity="0.18"></path>
                    <circle cx="140" cy="192" r="108" fill="none" stroke="rgba(243,237,226,0.72)" stroke-width="1.8" stroke-dasharray="3 3"></circle>
                    <circle cx="140" cy="192" r="90" fill="none" stroke="rgba(243,237,226,0.32)" stroke-width="1"></circle>
                    <line x1="42" y1="184" x2="238" y2="184" stroke="rgba(243,237,226,0.5)" stroke-width="1.6"></line>
                    <line x1="42" y1="193" x2="238" y2="193" stroke="rgba(243,237,226,0.5)" stroke-width="1.6"></line>
                    <line x1="42" y1="202" x2="238" y2="202" stroke="rgba(243,237,226,0.5)" stroke-width="1.6"></line>
                    <text x="140" y="176" text-anchor="middle" font-family="Georgia, serif" font-style="italic" font-size="22" fill="#f3ede2">Bangalore</text>
                    <text x="140" y="218" text-anchor="middle" font-family="monospace" font-size="7.5" letter-spacing="3" fill="rgba(243,237,226,0.42)">INDIA</text>
                    <text x="30" y="36" font-family="monospace" font-size="7.5" letter-spacing="2" fill="rgba(243,237,226,0.36)">DENOMINATION</text>
                    <text x="30" y="60" font-family="monospace" font-size="34" font-weight="500" fill="#f3ede2" letter-spacing="-1.5">24.0</text>
                    <text x="82" y="65" font-family="monospace" font-size="11" fill="rgba(243,237,226,0.48)">km</text>
                    <text x="30" y="334" font-family="monospace" font-size="8" fill="rgba(243,237,226,0.36)" letter-spacing="1.5">PACE</text>
                    <text x="30" y="352" font-family="monospace" font-size="13" fill="rgba(243,237,226,0.80)">5:30/km</text>
                    <text x="140" y="334" text-anchor="middle" font-family="monospace" font-size="8" fill="rgba(243,237,226,0.36)" letter-spacing="1.5">TIME</text>
                    <text x="140" y="352" text-anchor="middle" font-family="monospace" font-size="13" fill="rgba(243,237,226,0.80)">2:12:00</text>
                    <text x="250" y="334" text-anchor="end" font-family="monospace" font-size="7" fill="rgba(243,237,226,0.28)" letter-spacing="1">NO.</text>
                    <text x="250" y="352" text-anchor="end" font-family="monospace" font-size="11" fill="rgba(243,237,226,0.50)">A0001</text>
                  </svg>
                </div>
                <figcaption class="card-cap eyebrow">{cards[1].caption}</figcaption>
              </figure>
            </button>
          </li>

          <!-- 3: Customs — Tokyo half marathon -->
          <li class="gallery-item">
            <button class="gallery-trigger" aria-haspopup="dialog" aria-controls="modal-card-customs-tokyo" data-modal="modal-card-customs-tokyo" type="button">
              <figure class="card-figure" aria-label={cards[2].caption}>
                <div class="card-frame">
                  <svg viewBox="0 0 280 370" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="280" height="370" fill="#f5eedf"></rect>
                    {stripes.map((i) => (
                      <rect x={i * 28 - 30} y="0" width="14" height="370"
                        fill={i % 2 === 0 ? "#e85d2f" : "#14110d"}
                        opacity="0.07" transform="skewX(-14)"></rect>
                    ))}
                    <rect x="10" y="10" width="260" height="350" fill="none" stroke="rgba(28,24,18,0.20)" stroke-width="1" rx="1"></rect>
                    <rect x="14" y="14" width="252" height="342" fill="none" stroke="rgba(28,24,18,0.08)" stroke-width="0.6" rx="1"></rect>
                    <text x="24" y="34" font-family="monospace" font-size="6.5" letter-spacing="2" fill="rgba(28,24,18,0.38)">DEPARTMENT OF ATHLETIC AFFAIRS</text>
                    <text x="24" y="56" font-family="Georgia, serif" font-style="italic" font-size="20" fill="#1c1812">Declaration of Run</text>
                    <line x1="18" y1="64" x2="262" y2="64" stroke="rgba(28,24,18,0.15)" stroke-width="1"></line>
                    <line x1="18" y1="67" x2="262" y2="67" stroke="rgba(28,24,18,0.07)" stroke-width="0.5"></line>
                    {formRowsA.map(({ label, value }, i) => (
                      <>
                        <text x="24" y={88 + i * 34} font-family="monospace" font-size="7" letter-spacing="1.2" fill="rgba(28,24,18,0.40)">{label.toUpperCase()}</text>
                        <text x="256" y={88 + i * 34 + 12} text-anchor="end" font-family="monospace" font-size="12" fill="#1c1812">{value}</text>
                        <line x1="18" y1={88 + i * 34 + 18} x2="262" y2={88 + i * 34 + 18} stroke="rgba(28,24,18,0.08)" stroke-width="0.8" stroke-dasharray="3,3" />
                      </>
                    ))}
                    <rect x="22" y="354" width="12" height="12" fill="rgba(232,93,47,0.8)" stroke="none" rx="1"></rect>
                    <text x="40" y="363" font-family="monospace" font-size="7.5" fill="rgba(28,24,18,0.48)">PERSONAL BEST</text>
                    <circle cx="228" cy="352" r="22" fill="none" stroke="rgba(232,93,47,0.40)" stroke-width="1.4" stroke-dasharray="2 2"></circle>
                    <text x="228" y="349" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(232,93,47,0.52)" letter-spacing="1">2026</text>
                    <line x1="210" y1="354" x2="246" y2="354" stroke="rgba(232,93,47,0.28)" stroke-width="1"></line>
                    <text x="228" y="362" text-anchor="middle" font-family="monospace" font-size="6.5" fill="rgba(232,93,47,0.46)" letter-spacing="1">CLEARED</text>
                  </svg>
                </div>
                <figcaption class="card-cap eyebrow">{cards[2].caption}</figcaption>
              </figure>
            </button>
          </li>

          <!-- 4: Passport — London Hampstead Heath -->
          <li class="gallery-item">
            <button class="gallery-trigger" aria-haspopup="dialog" aria-controls="modal-card-passport-london" data-modal="modal-card-passport-london" type="button">
              <figure class="card-figure" aria-label={cards[3].caption}>
                <div class="card-frame">
                  <svg viewBox="0 0 280 370" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="280" height="370" fill="#f5eedf"></rect>
                    <!-- Guide rules -->
                    {Array.from({ length: 10 }, (_, i) => (
                      <line x1="18" y1={50 + i * 30} x2="262" y2={50 + i * 30} stroke="rgba(28,24,18,0.08)" stroke-width="0.6"></line>
                    ))}
                    <!-- Header strip -->
                    <line x1="18" y1="58" x2="262" y2="58" stroke="rgba(28,24,18,0.16)" stroke-width="0.8"></line>
                    <text x="24" y="34" font-family="monospace" font-size="8" letter-spacing="2" fill="rgba(28,24,18,0.45)">REPUBLIC OF RUNNING</text>
                    <text x="24" y="50" font-family="monospace" font-size="12" fill="#1c1812" letter-spacing="0.5">UNITED KINGDOM</text>
                    <text x="244" y="34" text-anchor="end" font-family="monospace" font-size="8" fill="rgba(28,24,18,0.45)" letter-spacing="1.5">ISSUED</text>
                    <text x="244" y="50" text-anchor="end" font-family="monospace" font-size="10" fill="#1c1812">17 MAR 2026</text>
                    <!-- ENTRY mark -->
                    <text x="24" y="118" font-family="Georgia, serif" font-style="italic" font-size="54" fill="#c44a1e" opacity="0.92" letter-spacing="-1">ENTRY</text>
                    <!-- City of entry -->
                    <text x="24" y="140" font-family="monospace" font-size="7.5" letter-spacing="2" fill="rgba(28,24,18,0.42)">CITY OF ENTRY</text>
                    <text x="24" y="156" font-family="Georgia, serif" font-size="16" fill="#1c1812">London</text>
                    <!-- Run title -->
                    <text x="24" y="178" font-family="monospace" font-size="7.5" letter-spacing="2" fill="rgba(28,24,18,0.42)">RUN TITLE</text>
                    <text x="24" y="194" font-family="Georgia, serif" font-style="italic" font-size="13" fill="rgba(28,24,18,0.72)">Hampstead Heath</text>
                    <!-- Vertical sep -->
                    <line x1="188" y1="66" x2="188" y2="296" stroke="rgba(28,24,18,0.12)" stroke-width="0.8"></line>
                    <!-- Distance column -->
                    <text x="204" y="84" font-family="monospace" font-size="7.5" letter-spacing="2" fill="rgba(28,24,18,0.42)">DISTANCE</text>
                    <text x="204" y="108" font-family="monospace" font-size="32" font-weight="500" fill="#1c1812" letter-spacing="-1.5">11.2</text>
                    <text x="204" y="120" font-family="monospace" font-size="8" fill="rgba(28,24,18,0.45)">km</text>
                    <text x="204" y="142" font-family="monospace" font-size="7.5" letter-spacing="2" fill="rgba(28,24,18,0.42)">AVG PACE</text>
                    <text x="204" y="162" font-family="monospace" font-size="22" font-weight="500" fill="#1c1812" letter-spacing="-0.5">5:22</text>
                    <text x="204" y="172" font-family="monospace" font-size="7.5" fill="rgba(28,24,18,0.45)">/km</text>
                    <text x="204" y="194" font-family="monospace" font-size="7.5" letter-spacing="2" fill="rgba(28,24,18,0.42)">DURATION</text>
                    <text x="204" y="214" font-family="monospace" font-size="18" font-weight="500" fill="#1c1812" letter-spacing="-0.3">1:00:00</text>
                    <!-- Passport stamp -->
                    <circle cx="230" cy="268" r="34" fill="none" stroke="#c44a1e" stroke-width="1.2" stroke-dasharray="2 2"></circle>
                    <circle cx="230" cy="268" r="24" fill="none" stroke="#c44a1e" stroke-width="0.8"></circle>
                    <text x="230" y="261" text-anchor="middle" font-family="monospace" font-size="7.5" letter-spacing="1.5" fill="#c44a1e">LONDON</text>
                    <text x="230" y="274" text-anchor="middle" font-family="monospace" font-size="11" font-weight="500" fill="#c44a1e" letter-spacing="-0.3">11.2</text>
                    <text x="230" y="284" text-anchor="middle" font-family="monospace" font-size="6.5" fill="#c44a1e" opacity="0.75">KM</text>
                    <!-- MRZ zone -->
                    <rect x="0" y="315" width="280" height="55" fill="rgba(28,24,18,0.04)"></rect>
                    <line x1="18" y1="316" x2="262" y2="316" stroke="rgba(28,24,18,0.16)" stroke-width="0.8"></line>
                    <text x="18" y="334" font-family="monospace" font-size="8" fill="rgba(28,24,18,0.45)" letter-spacing="1.2">P{'<'}GBR{'<'}LONDON{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}A0008{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}01120</text>
                    <text x="18" y="352" font-family="monospace" font-size="8" fill="rgba(28,24,18,0.45)" letter-spacing="1.2">260317032200LONDO{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}{'<'}</text>
                  </svg>
                </div>
                <figcaption class="card-cap eyebrow">{cards[3].caption}</figcaption>
              </figure>
            </button>
          </li>

          <!-- 5: Postage — Goa beach run -->
          <li class="gallery-item">
            <button class="gallery-trigger" aria-haspopup="dialog" aria-controls="modal-card-postage-goa" data-modal="modal-card-postage-goa" type="button">
              <figure class="card-figure" aria-label={cards[4].caption}>
                <div class="card-frame">
                  <svg viewBox="0 0 280 370" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="280" height="370" fill="#f3ede2"></rect>
                    <rect x="16" y="16" width="248" height="338" fill="#4a6b3a"></rect>
                    {Array.from({ length: 6 }, (_, row) => Array.from({ length: 11 }, (_, col) => (
                      <circle cx={30 + col * 22} cy={90 + row * 26} r={0.6 + ((row + col) % 3) * 0.18} fill="rgba(243,237,226,0.06)"></circle>
                    )))}
                    <path d="M40 285 Q80 260 120 272 Q152 282 180 248 Q208 215 248 235"
                      stroke="#f3ede2" stroke-width="2.2" fill="none" stroke-linecap="round" opacity="0.78" class="animated-route"></path>
                    <text x="30" y="42" font-family="monospace" font-size="7.5" letter-spacing="3.2" fill="rgba(243,237,226,0.55)">INDIA</text>
                    <text x="30" y="72" font-family="Georgia, serif" font-style="italic" font-size="30" fill="#f3ede2">Goa</text>
                    <rect x="192" y="28" width="58" height="18" fill="none" stroke="rgba(243,237,226,0.35)" stroke-width="1" rx="2"></rect>
                    <text x="221" y="41" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(243,237,226,0.55)">NO. A0007</text>
                    <text x="30" y="310" font-family="monospace" font-size="50" font-weight="500" fill="#f3ede2" letter-spacing="-2.5">9.40</text>
                    <text x="30" y="328" font-family="monospace" font-size="8" fill="rgba(243,237,226,0.48)" letter-spacing="2.8">KILOMETRES</text>
                    <text x="250" y="300" text-anchor="end" font-family="monospace" font-size="13.5" fill="rgba(243,237,226,0.82)">5:33/km</text>
                    <text x="250" y="318" text-anchor="end" font-family="monospace" font-size="10" fill="rgba(243,237,226,0.52)">52:05</text>
                    <text x="250" y="334" text-anchor="end" font-family="monospace" font-size="7.5" fill="rgba(243,237,226,0.30)" letter-spacing="0.6">2026 · APR · 12</text>
                    {p9L.map((i) => <circle cx="16" cy={32 + i * 36} r="9" fill="#f3ede2" />)}
                    {p9R.map((i) => <circle cx="264" cy={32 + i * 36} r="9" fill="#f3ede2" />)}
                    {p7T.map((i) => <circle cx={36 + i * 34} cy="16" r="9" fill="#f3ede2" />)}
                    {p7B.map((i) => <circle cx={36 + i * 34} cy="354" r="9" fill="#f3ede2" />)}
                  </svg>
                </div>
                <figcaption class="card-cap eyebrow">{cards[4].caption}</figcaption>
              </figure>
            </button>
          </li>

