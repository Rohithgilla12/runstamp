<script>
  const modal = document.getElementById("gallery-modal") as HTMLDivElement;
  const modalContent = document.getElementById("modal-content") as HTMLDivElement;
  const closeBtn = document.getElementById("modal-close-btn") as HTMLButtonElement;
  const closeBd = document.getElementById("modal-close-backdrop") as HTMLButtonElement;

  let lastFocused: HTMLElement | null = null;

  function openModal(trigger: HTMLButtonElement) {
    const figure = trigger.querySelector(".card-frame");
    if (!figure) return;

    lastFocused = trigger;
    modalContent.innerHTML = figure.innerHTML;
    modal.hidden = false;
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  }

  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = "";
    modalContent.innerHTML = "";
    lastFocused?.focus();
  }

  document.querySelectorAll<HTMLButtonElement>(".gallery-trigger").forEach((btn) => {
    btn.addEventListener("click", () => openModal(btn));
  });

  closeBtn.addEventListener("click", closeModal);
  closeBd.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.hidden) closeModal();
  });
</script>

