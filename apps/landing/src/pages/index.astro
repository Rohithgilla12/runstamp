---
import Base from "../layouts/Base.astro";
import WaitlistForm from "../components/WaitlistForm.astro";
import HeroPassStack from "../components/HeroPassStack.astro";

// Postage perforations
const perfH = (count: number) => Array.from({ length: count }, (_, i) => i);

// Hero card perforations
const perfLeft = perfH(9);
const perfRight = perfH(9);
const perfTop = perfH(7);
const perfBot = perfH(7);

// Customs form rows — real data from sample a1 (KBR Park long run)
const formRows = [
  { label: "Distance Declared", value: "24.02 KM" },
  { label: "Pace Declared",     value: "5:30 / KM" },
  { label: "Time Declared",     value: "2:12:00" },
  { label: "Elevation Gain",    value: "86 M" },
  { label: "Avg Heart Rate",    value: "152 BPM" },
  { label: "Purpose of Visit",  value: "Long Run — Endurance" },
  { label: "City of Origin",    value: "Hyderabad" },
  { label: "Country",           value: "India" },
];

// FAQ content
const faqs = [
  {
    q: "Do I have to give up Strava?",
    a: "No. Runstamp reads from Strava via their official API. Your Strava account, your followers, your segments — all untouched. Runstamp just sees the run data."
  },
  {
    q: "Will my data be sold?",
    a: "No. The API is open-source and auditable on GitHub. Your run data lives on your phone. Share-card uploads are opt-in, stored on Cloudflare R2, and can be deleted any time."
  },
  {
    q: "Does Apple Health work today?",
    a: "Yes — on iOS, tap Apple Health in Connections, grant read access, and Runstamp pulls your whole running history (years of it) plus per-workout HR, GPS route, splits, running power, vertical oscillation, ground contact time, stride length, and VO₂ max. New runs from your watch auto-sync the next time you open the app. Read-only — we never write back to Health."
  },
  {
    q: "What about Android?",
    a: "First-class support from day one — the app is React Native, not iOS-only. Android syncs from Health Connect (coming at launch) or Strava."
  },
  {
    q: "What about Garmin / Coros / Polar?",
    a: "On the roadmap. Strava sync covers most watches since they push to Strava automatically. Direct integrations follow after launch."
  },
  {
    q: "How is this different from Share Aura?",
    a: "Share Aura is iOS-only, closed-source, and share cards only. Runstamp is cross-platform, open-source, and adds the analytics dashboard and stamp passport — the share card is one of several outputs, not the entire product."
  },
  {
    q: "Is it actually free?",
    a: "Yes. The hosted version at runstamp.gilla.fun is free for individuals, with the full feature set. There is no premium tier hiding the good stuff."
  },
  {
    q: "Can I self-host it?",
    a: "Yes. docker-compose for the backend, Postgres, and Redis. You bring your own Strava API key, Firebase project, and R2 bucket. The documentation is written from day one to make this possible."
  },
  {
    q: "What's a Mythic stamp?",
    a: "Serious territory. Boston qualifier, sub-3 marathon, ultra finish, 100-day streak, every continent stamped. You earn them by running — not by using the app. We specifically didn't want Duolingo-style engagement badges."
  },
];

// Feature set
const features = [
  {
    key: "editor",
    label: "Editor",
    tagline: "Every run, a keepsake.",
    body: "Twelve templates — Postage, Postmark, Boarding Pass, Passport, Customs, Engraved, Wax Seal, Minimal, Date Stamp, Halftone, Cyanotype, Riso. Drop your own photo as the background of any of them. Drag stat stickers — distance, pace, HR chart, route map, splits. Export PNG to camera roll or share straight to Stories.",
    bg: "var(--ink)",
  },
  {
    key: "analytics",
    label: "Analytics",
    tagline: "Numbers runners actually want.",
    body: "Year / month / all-time views. Activity heatmap, monthly bars, distance histogram, training-load chart, streaks. Personal bests computed against every standard distance — 1K, mile, 5K, 10K, half, marathon. VO₂ max if your watch records it. No calories dashboard. No vanity scores.",
    bg: "var(--moss)",
  },
  {
    key: "passport",
    label: "Passport",
    tagline: "A stamp for every city.",
    body: "Every city your GPS landed in, reverse-geocoded once and pinned to a world map. The headline metric of the whole app — \"47 stamps · 6 countries · 3 continents.\" Shareable as its own card every December.",
    bg: "var(--ink-2)",
  },
  {
    key: "stamps",
    label: "Stamps",
    tagline: "Earned by running.",
    body: "Sixteen stamps across three tiers — Common, Rare, Mythic. The backend evaluates every synced run against the catalogue and awards the moment a rule passes. Boston qualifier at 3am while you're asleep just lands in your collection — no badges for opening the app.",
    bg: "var(--solar-deep, #c44a1e)",
  },
];
---

<Base>
  <!-- HEADER -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="wordmark" aria-label="Runstamp home">
        <svg width="22" height="22" viewBox="0 0 28 28" aria-hidden="true">
          <!-- Sun mark: circle + rays -->
          <circle cx="14" cy="14" r="5.5" fill="var(--solar)"></circle>
          {[0, 1, 2, 3, 4, 5, 6, 7].map((i) => {
            const a = (i * Math.PI * 2) / 8;
            return (
              <line
                x1={(14 + Math.cos(a) * 8.5).toFixed(2)}
                y1={(14 + Math.sin(a) * 8.5).toFixed(2)}
                x2={(14 + Math.cos(a) * 12).toFixed(2)}
                y2={(14 + Math.sin(a) * 12).toFixed(2)}
                stroke="var(--solar)"
                stroke-width="1.8"
                stroke-linecap="round"
              />
            );
          })}
        </svg>
        <span>Runstamp</span>
      </a>

      <nav aria-label="Site navigation">
        <ul class="nav-links">
          <li><a href="/stamps" class="nav-link">Stamps</a></li>
          <li><a href="/gallery" class="nav-link">Gallery</a></li>
          <li>
            <a href="#waitlist" class="nav-cta">Join waitlist</a>
          </li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section class="hero" aria-labelledby="hero-headline">
      <div class="container hero-inner">

        <!-- Left column: copy + form -->
        <div class="hero-copy">
          <p class="eyebrow hero-eyebrow">Open beta &middot; 2026</p>

          <h1 id="hero-headline" class="hero-headline">
            Collect a stamp<br />for every run.
          </h1>

          <p class="hero-sub">
            Runstamp turns your Strava and Apple Health runs into designed
            share cards, a passport of every city you've run in, and a
            catalogue of stamps earned by what you've done — not by using the
            app. Free and open source.
          </p>

          <!-- Hero waitlist form -->
          <div class="hero-form-wrap">
            <WaitlistForm source="landing-hero" id="hero" />
          </div>

          <ul class="store-badges" aria-label="Upcoming app store availability">
            <li>
              <span class="store-badge" aria-label="App Store — coming soon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.7 12.6c0-2.4 2-3.5 2.1-3.6-1.2-1.7-3-1.9-3.6-2-1.5-.2-3 .9-3.7.9-.8 0-2-.9-3.2-.8C7.3 7.2 6 8.2 5.2 9.7c-1.7 2.9-.4 7.2 1.2 9.5.8 1.1 1.7 2.4 2.9 2.4 1.2 0 1.6-.7 3-.7s1.8.7 3.1.7c1.3 0 2.1-1.2 2.9-2.3.9-1.3 1.3-2.5 1.3-2.6-.1 0-2.5-.9-2.5-3.8zm-2.4-7c.6-.8 1-1.9.9-3-1 0-2.1.6-2.8 1.4-.6.7-1.1 1.8-1 2.9 1.1.1 2.3-.5 2.9-1.3z"/>
                </svg>
                <span class="store-name">App Store</span>
                <span class="store-status eyebrow">Soon</span>
              </span>
            </li>
            <li>
              <span class="store-badge" aria-label="Google Play — coming soon">
                <svg width="14" height="16" viewBox="0 0 22 24" fill="currentColor" aria-hidden="true">
                  <path d="M1 .5C.5.8.2 1.3.2 2v20c0 .7.3 1.2.8 1.5L12 12.2 1 .5zm16.5 9.5L3.7.1 14 10.4l3.5-.4zm.8 1.5l-3.5 2 3.5 2.4L21 12zm-4.3 2.5L3.7 23.9l13.8-8.3-3.5-2z"/>
                </svg>
                <span class="store-name">Google Play</span>
                <span class="store-status eyebrow">Soon</span>
              </span>
            </li>
          </ul>
        </div>

        <!-- Right column: pass-stack of six share-card templates -->
        <div class="hero-stack-wrap">
          <HeroPassStack />
          <p class="hero-stack-hint" aria-hidden="true">
            Tap to flip through the deck.
          </p>
        </div>
      </div>
    </section>

    <!-- WHAT IT DOES — three columns, editorial rhythm -->
    <section class="features" aria-labelledby="features-headline">
      <div class="container">
        <header class="section-header">
          <p class="eyebrow">What it does</p>
          <h2 id="features-headline" class="section-headline">
            Four things.<br />Done well.
          </h2>
        </header>

        <ul class="features-list">
          {features.map((f, idx) => (
            <li class="feature-item" style={`--feature-bg: ${f.bg}`}>
              <div class="feature-stamp" aria-hidden="true">
                <svg viewBox="0 0 100 116" width="100" height="116">
                  <rect width="100" height="116" fill={f.bg} rx="1"></rect>
                  <!-- Perforations -->
                  {[0,1,2].map((i) => <circle cx="10" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
                  {[0,1,2].map((i) => <circle cx="90" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
                  {[0,1,2].map((i) => <circle cx={20 + i * 36} cy="10" r="6.5" fill="#f3ede2" />)}
                  {[0,1,2].map((i) => <circle cx={20 + i * 36} cy="106" r="6.5" fill="#f3ede2" />)}
                  {f.key === "editor" && (
                    <>
                      <rect x="30" y="28" width="32" height="40" fill="rgba(243,237,226,0.07)" stroke="rgba(243,237,226,0.25)" stroke-width="1" rx="1"></rect>
                      <rect x="35" y="23" width="32" height="40" fill="rgba(243,237,226,0.10)" stroke="rgba(243,237,226,0.35)" stroke-width="1" rx="1"></rect>
                      <rect x="40" y="18" width="32" height="40" fill="rgba(243,237,226,0.14)" stroke="rgba(243,237,226,0.45)" stroke-width="1" rx="1"></rect>
                      <line x1="45" y1="28" x2="66" y2="28" stroke="#e85d2f" stroke-width="1.5"></line>
                      <line x1="45" y1="35" x2="62" y2="35" stroke="rgba(243,237,226,0.28)" stroke-width="0.9"></line>
                      <line x1="45" y1="41" x2="59" y2="41" stroke="rgba(243,237,226,0.18)" stroke-width="0.9"></line>
                    </>
                  )}
                  {f.key === "analytics" && (
                    <>
                      <rect x="18" y="62" width="9" height="18" fill="rgba(243,237,226,0.30)" rx="1"></rect>
                      <rect x="31" y="50" width="9" height="30" fill="rgba(243,237,226,0.45)" rx="1"></rect>
                      <rect x="44" y="40" width="9" height="40" fill="rgba(243,237,226,0.60)" rx="1"></rect>
                      <rect x="57" y="32" width="9" height="48" fill="#f3ede2" rx="1"></rect>
                      <rect x="70" y="44" width="9" height="36" fill="rgba(243,237,226,0.50)" rx="1"></rect>
                      <text x="45" y="22" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(243,237,226,0.5)" letter-spacing="2">PACE</text>
                    </>
                  )}
                  {f.key === "passport" && (
                    <>
                      <circle cx="45" cy="56" r="24" fill="none" stroke="rgba(243,237,226,0.22)" stroke-width="1.2"></circle>
                      <ellipse cx="45" cy="56" rx="11" ry="24" fill="none" stroke="rgba(243,237,226,0.14)" stroke-width="0.8"></ellipse>
                      <line x1="21" y1="56" x2="69" y2="56" stroke="rgba(243,237,226,0.14)" stroke-width="0.8"></line>
                      <circle cx="32" cy="46" r="2.5" fill="#e85d2f"></circle>
                      <circle cx="55" cy="60" r="2.5" fill="#e85d2f"></circle>
                      <circle cx="47" cy="36" r="2.5" fill="#e85d2f"></circle>
                    </>
                  )}
                  {f.key === "stamps" && (
                    <>
                      {/* Cancellation ring */}
                      <circle cx="45" cy="56" r="22" fill="none" stroke="rgba(243,237,226,0.55)" stroke-width="1.2" stroke-dasharray="2 2"></circle>
                      <circle cx="45" cy="56" r="15" fill="none" stroke="rgba(243,237,226,0.32)" stroke-width="0.9"></circle>
                      {/* Cancel bars across the rim */}
                      <line x1="24" y1="52" x2="66" y2="52" stroke="rgba(243,237,226,0.4)" stroke-width="0.9"></line>
                      <line x1="24" y1="60" x2="66" y2="60" stroke="rgba(243,237,226,0.4)" stroke-width="0.9"></line>
                      {/* Star at the centre */}
                      <path d="M45 42 L47.5 50 L56 50 L49 55 L51.5 63 L45 58 L38.5 63 L41 55 L34 50 L42.5 50 Z" fill="rgba(243,237,226,0.92)"></path>
                    </>
                  )}
                </svg>
              </div>

              <div class="feature-copy">
                <span class="eyebrow feature-num">0{idx + 1}</span>
                <h3 class="feature-label">{f.label}</h3>
                <p class="feature-tagline">{f.tagline}</p>
                <p class="feature-body">{f.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- SAMPLE SHARE CARDS — gallery preview -->
    <section class="cards-preview" aria-labelledby="cards-headline">
      <div class="container">
        <header class="section-header section-header--split">
          <div>
            <p class="eyebrow">Share cards</p>
            <h2 id="cards-headline" class="section-headline">
              Every run,<br />a designed artifact.
            </h2>
          </div>
          <p class="section-desc">
            Twelve templates ship — Postage, Postmark, Passport, Boarding
            Pass, Customs, Engraved, Wax Seal, Minimal, Date Stamp, Halftone,
            Cyanotype, Riso. Each rooted in the same postage metaphor; each
            making a different compositional argument. Drop your own photo
            behind any of them. The share card is a stamp you pressed yourself.
            <a href="/gallery" class="text-link">See full gallery &rarr;</a>
          </p>
        </header>

        <div class="cards-grid">

          <!-- Card 1: Postmark — dark -->
          <figure class="share-card" aria-labelledby="c1-cap">
            <div class="card-wrap">
              <svg viewBox="0 0 280 370" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="280" height="370" fill="#14110d"></rect>
                <!-- Faint route backdrop -->
                <path d="M30 320 Q70 255 110 285 Q150 315 185 250 Q220 185 258 210"
                  stroke="#e85d2f" stroke-width="3.5" fill="none" stroke-linecap="round" opacity="0.15"></path>
                <!-- Giant postmark ring -->
                <circle cx="140" cy="192" r="108" fill="none" stroke="rgba(243,237,226,0.72)" stroke-width="1.8" stroke-dasharray="3 3"></circle>
                <circle cx="140" cy="192" r="90" fill="none" stroke="rgba(243,237,226,0.32)" stroke-width="1"></circle>
                <!-- Cancel bars -->
                <line x1="42" y1="184" x2="238" y2="184" stroke="rgba(243,237,226,0.5)" stroke-width="1.6"></line>
                <line x1="42" y1="193" x2="238" y2="193" stroke="rgba(243,237,226,0.5)" stroke-width="1.6"></line>
                <line x1="42" y1="202" x2="238" y2="202" stroke="rgba(243,237,226,0.5)" stroke-width="1.6"></line>
                <!-- City inside ring -->
                <text x="140" y="176" text-anchor="middle" font-family="Georgia, serif" font-style="italic" font-size="22" fill="#f3ede2">Hyderabad</text>
                <text x="140" y="218" text-anchor="middle" font-family="monospace" font-size="7.5" letter-spacing="3" fill="rgba(243,237,226,0.42)">INDIA</text>
                <!-- Distance header -->
                <text x="30" y="36" font-family="monospace" font-size="7.5" letter-spacing="2" fill="rgba(243,237,226,0.36)">DENOMINATION</text>
                <text x="30" y="60" font-family="monospace" font-size="34" font-weight="500" fill="#f3ede2" letter-spacing="-1.5">32.0</text>
                <text x="82" y="65" font-family="monospace" font-size="11" fill="rgba(243,237,226,0.48)">km</text>
                <!-- Stats bottom -->
                <text x="30" y="334" font-family="monospace" font-size="8" fill="rgba(243,237,226,0.36)" letter-spacing="1.5">PACE</text>
                <text x="30" y="350" font-family="monospace" font-size="13" fill="rgba(243,237,226,0.78)">4:58/km</text>
                <text x="140" y="334" text-anchor="middle" font-family="monospace" font-size="8" fill="rgba(243,237,226,0.36)" letter-spacing="1.5">TIME</text>
                <text x="140" y="350" text-anchor="middle" font-family="monospace" font-size="13" fill="rgba(243,237,226,0.78)">2:39:14</text>
                <!-- Run no. -->
                <text x="250" y="334" text-anchor="end" font-family="monospace" font-size="7" fill="rgba(243,237,226,0.28)" letter-spacing="1">NO.</text>
                <text x="250" y="350" text-anchor="end" font-family="monospace" font-size="11" fill="rgba(243,237,226,0.48)">A0001</text>
              </svg>
            </div>
            <figcaption id="c1-cap" class="card-caption eyebrow">Postmark — Hyderabad · 32 km</figcaption>
          </figure>

          <!-- Card 2: Postage — dark paper -->
          <figure class="share-card share-card--tall" aria-labelledby="c2-cap">
            <div class="card-wrap">
              <svg viewBox="0 0 280 370" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="280" height="370" fill="#f3ede2"></rect>
                <rect x="16" y="16" width="248" height="338" fill="#14110d"></rect>
                {Array.from({ length: 6 }, (_, row) =>
                  Array.from({ length: 11 }, (_, col) => (
                    <circle cx={30 + col * 22} cy={90 + row * 26} r={0.6 + ((row + col) % 3) * 0.18} fill="rgba(243,237,226,0.05)"></circle>
                  ))
                )}
                <path d="M50 285 Q80 250 110 268 Q140 286 165 240 Q190 195 220 215 Q248 235 248 200"
                  stroke="#e85d2f" stroke-width="2.2" fill="none" stroke-linecap="round" opacity="0.85"></path>
                <text x="30" y="42" font-family="monospace" font-size="7.5" letter-spacing="3.2" fill="rgba(243,237,226,0.48)">JAPAN</text>
                <text x="30" y="72" font-family="Georgia, serif" font-style="italic" font-size="30" fill="#f3ede2">Tokyo</text>
                <rect x="194" y="28" width="56" height="18" fill="none" stroke="rgba(243,237,226,0.28)" stroke-width="1" rx="2"></rect>
                <text x="222" y="41" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(243,237,226,0.48)">NO. A0009</text>
                <text x="30" y="310" font-family="monospace" font-size="50" font-weight="500" fill="#f3ede2" letter-spacing="-2.5">21.1</text>
                <text x="30" y="328" font-family="monospace" font-size="8" fill="rgba(243,237,226,0.42)" letter-spacing="2.8">KILOMETRES</text>
                <text x="250" y="300" text-anchor="end" font-family="monospace" font-size="13.5" fill="rgba(243,237,226,0.78)">5:12/km</text>
                <text x="250" y="318" text-anchor="end" font-family="monospace" font-size="10" fill="rgba(243,237,226,0.46)">1:49:43</text>
                <!-- Postmark circle watermark -->
                <circle cx="208" cy="178" r="36" fill="none" stroke="rgba(243,237,226,0.09)" stroke-width="1.2" stroke-dasharray="2 3"></circle>
                <!-- Perfs -->
                {perfLeft.map((i) => <circle cx="16" cy={32 + i * 36} r="9" fill="#f3ede2" />)}
                {perfRight.map((i) => <circle cx="264" cy={32 + i * 36} r="9" fill="#f3ede2" />)}
                {perfTop.map((i) => <circle cx={36 + i * 34} cy="16" r="9" fill="#f3ede2" />)}
                {perfBot.map((i) => <circle cx={36 + i * 34} cy="354" r="9" fill="#f3ede2" />)}
              </svg>
            </div>
            <figcaption id="c2-cap" class="card-caption eyebrow">Postage — Tokyo · 21.1 km</figcaption>
          </figure>

          <!-- Card 3: Customs — cream paper -->
          <figure class="share-card" aria-labelledby="c3-cap">
            <div class="card-wrap">
              <svg viewBox="0 0 280 370" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="280" height="370" fill="#f5eedf"></rect>
                <!-- Airmail diagonal stripes -->
                {Array.from({ length: 22 }, (_, i) => (
                  <rect
                    x={i * 28 - 30} y="0"
                    width="14" height="370"
                    fill={i % 2 === 0 ? "#e85d2f" : "#14110d"}
                    opacity="0.07"
                    transform="skewX(-14)"
                  />
                ))}
                <!-- Form border -->
                <rect x="10" y="10" width="260" height="350" fill="none" stroke="rgba(28,24,18,0.20)" stroke-width="1" rx="1"></rect>
                <rect x="14" y="14" width="252" height="342" fill="none" stroke="rgba(28,24,18,0.08)" stroke-width="0.6" rx="1"></rect>
                <!-- Header -->
                <text x="24" y="36" font-family="monospace" font-size="7" letter-spacing="2" fill="rgba(28,24,18,0.38)">DEPARTMENT OF ATHLETIC AFFAIRS</text>
                <text x="24" y="58" font-family="Georgia, serif" font-style="italic" font-size="20" fill="#1c1812">Declaration of Run</text>
                <line x1="18" y1="66" x2="262" y2="66" stroke="rgba(28,24,18,0.15)" stroke-width="1"></line>
                <line x1="18" y1="69" x2="262" y2="69" stroke="rgba(28,24,18,0.07)" stroke-width="0.5"></line>
                <!-- Form rows -->
                {formRows.map(({ label, value }, i) => (
                  <>
                    <text x="24" y={90 + i * 32} font-family="monospace" font-size="7" letter-spacing="1.2" fill="rgba(28,24,18,0.40)">{label.toUpperCase()}</text>
                    <text x="256" y={90 + i * 32 + 13} text-anchor="end" font-family="monospace" font-size="12" fill="#1c1812">{value}</text>
                    <line x1="18" y1={90 + i * 32 + 18} x2="262" y2={90 + i * 32 + 18} stroke="rgba(28,24,18,0.08)" stroke-width="0.8" stroke-dasharray="3,3" />
                  </>
                ))}
                <!-- PB checkbox -->
                <rect x="24" y="348" width="13" height="13" fill="none" stroke="#1c1812" stroke-width="1.2" rx="1"></rect>
                <text x="42" y="358" font-family="monospace" font-size="7.5" fill="rgba(28,24,18,0.48)">PERSONAL BEST</text>
                <!-- Circular stamp watermark -->
                <circle cx="228" cy="352" r="22" fill="none" stroke="rgba(232,93,47,0.40)" stroke-width="1.4" stroke-dasharray="2 2"></circle>
