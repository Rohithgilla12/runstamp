---
import Base from "../layouts/Base.astro";

const sunRayAngles = Array.from({ length: 8 }, (_, i) => (i * Math.PI * 2) / 8);

const formRows = [
  { label: "DISTANCE DECLARED", value: "21.1 KM" },
  { label: "PACE DECLARED", value: "5:12 / KM" },
  { label: "TIME DECLARED", value: "1:49:43" },
  { label: "ELEVATION GAIN", value: "312 M" },
  { label: "PURPOSE OF VISIT", value: "LONG RUN" },
  { label: "CITY OF ORIGIN", value: "TOKYO" },
  { label: "COUNTRY", value: "JAPAN" },
];

const airmailStripes = Array.from({ length: 20 }, (_, i) => i);
const halftoneRows = Array.from({ length: 8 }, (_, row) =>
  Array.from({ length: 12 }, (_, col) => ({ row, col }))
);

// Perforated edge helpers — circle positions along each edge
const perfSide = (count: number) =>
  Array.from({ length: count }, (_, i) => i);
---

<Base>
  <header class="site-header">
    <div class="container">
      <div class="wordmark" aria-label="Runstamp">
        <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="4.8" fill="var(--solar)"></circle>
          {sunRayAngles.map((a) => (
            <line
              x1={12 + Math.cos(a) * 7.2}
              y1={12 + Math.sin(a) * 7.2}
              x2={12 + Math.cos(a) * 10.5}
              y2={12 + Math.sin(a) * 10.5}
              stroke="var(--solar)"
              stroke-width="1.6"
              stroke-linecap="round"
            />
          ))}
        </svg>
        <span>Runstamp</span>
      </div>
      <a href="#waitlist" class="header-cta">Join waitlist</a>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section class="hero" aria-labelledby="hero-headline">
      <div class="container hero-inner">
        <div class="hero-text">
          <p class="eyebrow hero-eyebrow">Open beta · 2026</p>
          <h1 id="hero-headline" class="hero-headline">
            Collect a stamp<br />for every run.
          </h1>
          <p class="hero-sub">
            Turn your Strava and Apple Health runs into beautiful share cards, a
            passport of cities you've run in, and a catalogue of stamps earned.
            Free and open source.
          </p>
          <ul class="store-badges">
            <li>
              <a
                href="#waitlist"
                class="store-badge"
                aria-label="App Store — coming soon, join waitlist"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.7 12.6c0-2.4 2-3.5 2.1-3.6-1.2-1.7-3-1.9-3.6-2-1.5-.2-3 .9-3.7.9-.8 0-2-.9-3.2-.8C7.3 7.2 6 8.2 5.2 9.7c-1.7 2.9-.4 7.2 1.2 9.5.8 1.1 1.7 2.4 2.9 2.4 1.2 0 1.6-.7 3-.7s1.8.7 3.1.7c1.3 0 2.1-1.2 2.9-2.3.9-1.3 1.3-2.5 1.3-2.6-.1 0-2.5-.9-2.5-3.8zm-2.4-7c.6-.8 1-1.9.9-3-1 0-2.1.6-2.8 1.4-.6.7-1.1 1.8-1 2.9 1.1.1 2.3-.5 2.9-1.3z" />
                </svg>
                <span>
                  <span class="badge-platform">App Store</span>
                  <span class="badge-status">Coming soon</span>
                </span>
              </a>
            </li>
            <li>
              <a
                href="#waitlist"
                class="store-badge"
                aria-label="Google Play — coming soon, join waitlist"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M3 20.5v-17c0-.83 1-.83 1.5-.5l14 8.5-14 8.5C3.5 21.33 3 21.33 3 20.5z" />
                </svg>
                <span>
                  <span class="badge-platform">Google Play</span>
                  <span class="badge-status">Coming soon</span>
                </span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Hero share card: Postage template mock -->
        <div class="hero-card">
          <figure aria-label="Sample Runstamp share card — Postage template" class="hero-card-figure">
            <svg
              viewBox="0 0 280 380"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              class="hero-card-svg"
            >
              <!-- Paper backing behind perforations -->
              <rect width="280" height="380" fill="#f3ede2"></rect>
              <!-- Card body fills inside the perforated border -->
              <rect x="16" y="16" width="248" height="348" fill="#14110d"></rect>

              <!-- Halftone dots (decorative texture) -->
              {halftoneRows.map((row) =>
                row.map(({ row: r, col: c }) => (
                  <circle
                    cx={28 + c * 20}
                    cy={80 + r * 22}
                    r={0.7 + ((r + c) % 3) * 0.25}
                    fill="rgba(243,237,226,0.06)"
                  />
                ))
              )}

              <!-- Route polyline -->
              <path
                d="M50 300 Q75 265 100 280 Q125 295 150 255 Q175 215 200 235 Q225 255 248 220"
                stroke="#e85d2f"
                stroke-width="2.5"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
                opacity="0.85"
              ></path>

              <!-- Country eyebrow -->
              <text x="32" y="44" font-family="monospace" font-size="8" letter-spacing="3" fill="rgba(243,237,226,0.5)">JAPAN</text>
              <!-- City -->
              <text x="32" y="72" font-family="Georgia, serif" font-style="italic" font-size="28" fill="#f3ede2">Tokyo</text>
              <!-- Run ID badge -->
              <rect x="194" y="32" width="54" height="18" fill="none" stroke="rgba(243,237,226,0.3)" stroke-width="1" rx="2"></rect>
              <text x="221" y="45" text-anchor="middle" font-family="monospace" font-size="7.5" fill="rgba(243,237,226,0.5)">NO. A0041</text>

              <!-- Distance denomination -->
              <text x="32" y="326" font-family="monospace" font-size="42" font-weight="500" fill="#f3ede2" letter-spacing="-2">21.1</text>
              <text x="32" y="344" font-family="monospace" font-size="8.5" fill="rgba(243,237,226,0.45)" letter-spacing="2.5">KILOMETRES</text>

              <!-- Pace + time -->
              <text x="248" y="320" text-anchor="end" font-family="monospace" font-size="13" fill="rgba(243,237,226,0.75)">5:12/km</text>
              <text x="248" y="336" text-anchor="end" font-family="monospace" font-size="10" fill="rgba(243,237,226,0.45)">1:49:43</text>

              <!-- Date stamp -->
              <text x="248" y="352" text-anchor="end" font-family="monospace" font-size="8" fill="rgba(243,237,226,0.3)" letter-spacing="0.5">2026 · MAR · 15</text>

              <!-- Perforated left edge circles punching through to cream paper -->
              {perfSide(11).map((i) => (
                <circle cx="16" cy={34 + i * 32} r="8" fill="#f3ede2" />
              ))}
              <!-- Perforated right edge -->
              {perfSide(11).map((i) => (
                <circle cx="264" cy={34 + i * 32} r="8" fill="#f3ede2" />
              ))}
              <!-- Perforated top edge -->
              {perfSide(8).map((i) => (
                <circle cx={36 + i * 32} cy="16" r="8" fill="#f3ede2" />
              ))}
              <!-- Perforated bottom edge -->
              {perfSide(8).map((i) => (
                <circle cx={36 + i * 32} cy="364" r="8" fill="#f3ede2" />
              ))}
            </svg>
            <figcaption class="visually-hidden">
              Sample Runstamp share card: Postage template — Tokyo half marathon, 21.1 km, pace 5:12/km, time 1:49:43
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- WHAT IT DOES -->
    <section class="features" aria-labelledby="features-headline">
      <div class="container">
        <p class="eyebrow section-eyebrow">What it does</p>
        <h2 id="features-headline" class="section-headline">
          Three things. Done well.
        </h2>

        <ul class="features-grid">
          <li class="feature-card">
            <!-- Stamp-framed mini illustration: Editor -->
            <div class="stamp-illus" aria-hidden="true">
              <svg viewBox="0 0 90 90" width="90" height="90">
                <rect width="90" height="90" fill="#14110d" rx="1"></rect>
                <!-- Perf circles -->
                {[0,1,2].map((i) => <circle cx="10" cy={20 + i * 28} r="5.5" fill="#f3ede2" />)}
                {[0,1,2].map((i) => <circle cx="80" cy={20 + i * 28} r="5.5" fill="#f3ede2" />)}
                {[0,1,2].map((i) => <circle cx={20 + i * 28} cy="10" r="5.5" fill="#f3ede2" />)}
                {[0,1,2].map((i) => <circle cx={20 + i * 28} cy="80" r="5.5" fill="#f3ede2" />)}
                <!-- Editor icon: layers / cards -->
                <rect x="25" y="28" width="32" height="40" fill="rgba(243,237,226,0.08)" stroke="rgba(243,237,226,0.3)" stroke-width="1" rx="1"></rect>
                <rect x="30" y="24" width="32" height="40" fill="rgba(243,237,226,0.1)" stroke="rgba(243,237,226,0.4)" stroke-width="1" rx="1"></rect>
                <rect x="35" y="20" width="32" height="40" fill="rgba(243,237,226,0.15)" stroke="rgba(243,237,226,0.5)" stroke-width="1" rx="1"></rect>
                <line x1="40" y1="30" x2="62" y2="30" stroke="#e85d2f" stroke-width="1.5"></line>
                <line x1="40" y1="37" x2="58" y2="37" stroke="rgba(243,237,226,0.3)" stroke-width="1"></line>
                <line x1="40" y1="42" x2="55" y2="42" stroke="rgba(243,237,226,0.2)" stroke-width="1"></line>
              </svg>
            </div>
            <h3 class="feature-title">Editor</h3>
            <p class="feature-body">
              Pick a template — postage stamp, postmark, passport entry, customs
              form. Layer in your route map or a photo from the run. Export PNG
              and share.
            </p>
          </li>

          <li class="feature-card">
            <!-- Stamp-framed mini illustration: Analytics -->
            <div class="stamp-illus" aria-hidden="true">
              <svg viewBox="0 0 90 90" width="90" height="90">
                <rect width="90" height="90" fill="#4a6b3a" rx="1"></rect>
                {[0,1,2].map((i) => <circle cx="10" cy={20 + i * 28} r="5.5" fill="#f3ede2" />)}
                {[0,1,2].map((i) => <circle cx="80" cy={20 + i * 28} r="5.5" fill="#f3ede2" />)}
                {[0,1,2].map((i) => <circle cx={20 + i * 28} cy="10" r="5.5" fill="#f3ede2" />)}
                {[0,1,2].map((i) => <circle cx={20 + i * 28} cy="80" r="5.5" fill="#f3ede2" />)}
                <!-- Pace chart bars -->
                <rect x="20" y="62" width="8" height="16" fill="rgba(243,237,226,0.35)" rx="1"></rect>
                <rect x="32" y="50" width="8" height="28" fill="rgba(243,237,226,0.5)" rx="1"></rect>
                <rect x="44" y="42" width="8" height="36" fill="rgba(243,237,226,0.65)" rx="1"></rect>
                <rect x="56" y="34" width="8" height="44" fill="#f3ede2" rx="1"></rect>
                <rect x="68" y="46" width="8" height="32" fill="rgba(243,237,226,0.55)" rx="1"></rect>
                <text x="45" y="22" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(243,237,226,0.6)" letter-spacing="2">PACE</text>
              </svg>
            </div>
            <h3 class="feature-title">Analytics</h3>
            <p class="feature-body">
              Pace, splits, HR zones, weekly volume, best efforts. The numbers
              runners actually care about — not "calories burned," not "activity
              score."
            </p>
          </li>

          <li class="feature-card">
            <!-- Stamp-framed mini illustration: Passport/map -->
            <div class="stamp-illus" aria-hidden="true">
              <svg viewBox="0 0 90 90" width="90" height="90">
                <rect width="90" height="90" fill="#14110d" rx="1"></rect>
                {[0,1,2].map((i) => <circle cx="10" cy={20 + i * 28} r="5.5" fill="#f3ede2" />)}
                {[0,1,2].map((i) => <circle cx="80" cy={20 + i * 28} r="5.5" fill="#f3ede2" />)}
                {[0,1,2].map((i) => <circle cx={20 + i * 28} cy="10" r="5.5" fill="#f3ede2" />)}
                {[0,1,2].map((i) => <circle cx={20 + i * 28} cy="80" r="5.5" fill="#f3ede2" />)}
                <!-- Globe outline -->
                <circle cx="45" cy="46" r="26" fill="none" stroke="rgba(243,237,226,0.25)" stroke-width="1.2"></circle>
                <ellipse cx="45" cy="46" rx="12" ry="26" fill="none" stroke="rgba(243,237,226,0.18)" stroke-width="1"></ellipse>
                <line x1="19" y1="46" x2="71" y2="46" stroke="rgba(243,237,226,0.18)" stroke-width="1"></line>
                <!-- City pin dots -->
                <circle cx="32" cy="38" r="2.5" fill="#e85d2f"></circle>
                <circle cx="55" cy="52" r="2.5" fill="#e85d2f"></circle>
                <circle cx="48" cy="32" r="2.5" fill="#e85d2f"></circle>
              </svg>
            </div>
            <h3 class="feature-title">Passport</h3>
            <p class="feature-body">
              Every city you've run in, pinned on a world map. A collection of
              stamps you earned — distance milestones, streak badges, rare
              Mythic stamps for the uncommonly obsessed.
            </p>
          </li>
        </ul>
      </div>
    </section>

    <!-- STAMP CATALOGUE -->
    <section class="stamps" aria-labelledby="stamps-headline">
      <div class="container">
        <p class="eyebrow section-eyebrow">Stamp catalogue</p>
        <h2 id="stamps-headline" class="section-headline">
          Earn them. Catalogue them.<br />Show them off — or don't.
        </h2>

        <ul class="stamp-row" aria-label="Example stamps from the catalogue">
          <!-- 50 km distance -->
          <li class="stamp-badge">
            <svg width="100" height="116" viewBox="0 0 100 116" aria-label="50 km distance stamp" role="img">
              <rect width="100" height="116" fill="#14110d" rx="1"></rect>
              {perfSide(3).map((i) => <circle cx="10" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx="90" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="10" r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="106" r="6.5" fill="#f3ede2" />)}
              <text x="50" y="40" text-anchor="middle" font-family="monospace" font-size="8.5" letter-spacing="3" fill="rgba(243,237,226,0.45)">DISTANCE</text>
              <text x="50" y="72" text-anchor="middle" font-family="Georgia, serif" font-style="italic" font-size="34" fill="#f3ede2">50</text>
              <text x="50" y="86" text-anchor="middle" font-family="monospace" font-size="9" fill="rgba(243,237,226,0.55)" letter-spacing="2">KM</text>
              <rect x="24" y="94" width="52" height="1" fill="rgba(243,237,226,0.18)"></rect>
              <text x="50" y="108" text-anchor="middle" font-family="monospace" font-size="7.5" fill="rgba(243,237,226,0.35)" letter-spacing="1.5">MILESTONE</text>
            </svg>
            <p class="stamp-label">50 km</p>
          </li>

          <!-- 7-day streak -->
          <li class="stamp-badge">
            <svg width="100" height="116" viewBox="0 0 100 116" aria-label="7-day streak stamp" role="img">
              <rect width="100" height="116" fill="#4a6b3a" rx="1"></rect>
              {perfSide(3).map((i) => <circle cx="10" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx="90" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="10" r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="106" r="6.5" fill="#f3ede2" />)}
              <text x="50" y="40" text-anchor="middle" font-family="monospace" font-size="8.5" letter-spacing="3" fill="rgba(243,237,226,0.45)">STREAK</text>
              <text x="50" y="72" text-anchor="middle" font-family="Georgia, serif" font-style="italic" font-size="34" fill="#f3ede2">7</text>
              <text x="50" y="86" text-anchor="middle" font-family="monospace" font-size="9" fill="rgba(243,237,226,0.55)" letter-spacing="2">DAYS</text>
              <rect x="24" y="94" width="52" height="1" fill="rgba(243,237,226,0.2)"></rect>
              <text x="50" y="108" text-anchor="middle" font-family="monospace" font-size="7.5" fill="rgba(243,237,226,0.4)" letter-spacing="1.5">STREAK</text>
            </svg>
            <p class="stamp-label">7-day streak</p>
          </li>

          <!-- Tokyo city -->
          <li class="stamp-badge">
            <svg width="100" height="116" viewBox="0 0 100 116" aria-label="Tokyo city stamp" role="img">
              <rect width="100" height="116" fill="#14110d" rx="1"></rect>
              {perfSide(3).map((i) => <circle cx="10" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx="90" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="10" r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="106" r="6.5" fill="#f3ede2" />)}
              <circle cx="50" cy="60" r="28" fill="none" stroke="rgba(243,237,226,0.22)" stroke-width="1.5"></circle>
              <circle cx="50" cy="60" r="22" fill="none" stroke="rgba(243,237,226,0.12)" stroke-width="1"></circle>
              <text x="50" y="56" text-anchor="middle" font-family="Georgia, serif" font-style="italic" font-size="15" fill="#f3ede2">Tokyo</text>
              <line x1="28" y1="63" x2="72" y2="63" stroke="rgba(243,237,226,0.28)" stroke-width="1.2"></line>
              <line x1="28" y1="69" x2="72" y2="69" stroke="rgba(243,237,226,0.28)" stroke-width="1.2"></line>
              <text x="50" y="80" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(243,237,226,0.35)" letter-spacing="1.5">JAPAN</text>
              <text x="50" y="108" text-anchor="middle" font-family="monospace" font-size="7.5" fill="rgba(243,237,226,0.35)" letter-spacing="1.5">CITY RUN</text>
            </svg>
            <p class="stamp-label">Tokyo</p>
          </li>

          <!-- Marathon 42.2 -->
          <li class="stamp-badge">
            <svg width="100" height="116" viewBox="0 0 100 116" aria-label="Marathon 42.2 km stamp" role="img">
              <rect width="100" height="116" fill="#e85d2f" rx="1"></rect>
              {perfSide(3).map((i) => <circle cx="10" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx="90" cy={20 + i * 36} r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="10" r="6.5" fill="#f3ede2" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="106" r="6.5" fill="#f3ede2" />)}
              <text x="50" y="40" text-anchor="middle" font-family="monospace" font-size="8" letter-spacing="2.5" fill="rgba(243,237,226,0.65)">MARATHON</text>
              <text x="50" y="72" text-anchor="middle" font-family="Georgia, serif" font-style="italic" font-size="26" fill="#f3ede2">42.2</text>
              <text x="50" y="86" text-anchor="middle" font-family="monospace" font-size="9" fill="rgba(243,237,226,0.65)" letter-spacing="2">KM</text>
              <rect x="24" y="93" width="52" height="1" fill="rgba(243,237,226,0.3)"></rect>
              <text x="50" y="108" text-anchor="middle" font-family="monospace" font-size="7.5" fill="rgba(243,237,226,0.55)" letter-spacing="1.5">FULL</text>
            </svg>
            <p class="stamp-label">Marathon</p>
          </li>

          <!-- Mythic 1000 km — foil treatment via gradient -->
          <li class="stamp-badge stamp-badge--mythic">
            <svg width="100" height="116" viewBox="0 0 100 116" aria-label="Mythic: 1000 km stamp" role="img" class="mythic-svg">
              <defs>
                <linearGradient id="foil" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#c9b05a"></stop>
                  <stop offset="25%" stop-color="#e8d4a0"></stop>
                  <stop offset="50%" stop-color="#a07840"></stop>
                  <stop offset="75%" stop-color="#d4b870"></stop>
                  <stop offset="100%" stop-color="#c9b05a"></stop>
                </linearGradient>
              </defs>
              <rect width="100" height="116" fill="#1c1812" rx="1"></rect>
              <rect x="1.5" y="1.5" width="97" height="113" fill="none" stroke="url(#foil)" stroke-width="1.5" rx="1"></rect>
              {perfSide(3).map((i) => <circle cx="10" cy={20 + i * 36} r="6.5" fill="#1c1812" stroke="url(#foil)" stroke-width="1" />)}
              {perfSide(3).map((i) => <circle cx="90" cy={20 + i * 36} r="6.5" fill="#1c1812" stroke="url(#foil)" stroke-width="1" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="10" r="6.5" fill="#1c1812" stroke="url(#foil)" stroke-width="1" />)}
              {perfSide(3).map((i) => <circle cx={20 + i * 36} cy="106" r="6.5" fill="#1c1812" stroke="url(#foil)" stroke-width="1" />)}
              <text x="50" y="36" text-anchor="middle" font-family="monospace" font-size="8" letter-spacing="3" fill="url(#foil)">MYTHIC</text>
              <!-- 5-pointed star -->
              <path d="M50 42 L52.9 51 L62 51 L54.6 56.5 L57.4 65.5 L50 60 L42.6 65.5 L45.4 56.5 L38 51 L47.1 51 Z" fill="url(#foil)"></path>
              <text x="50" y="82" text-anchor="middle" font-family="Georgia, serif" font-style="italic" font-size="14" fill="url(#foil)">1,000 km</text>
              <rect x="18" y="89" width="64" height="1" fill="url(#foil)" opacity="0.4"></rect>
              <text x="50" y="104" text-anchor="middle" font-family="monospace" font-size="7.5" fill="url(#foil)" letter-spacing="2">OBSESSED</text>
            </svg>
            <p class="stamp-label">Mythic</p>
          </li>

          <!-- Sub-4 hour -->
          <li class="stamp-badge">
