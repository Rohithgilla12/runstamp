# Runstamp self-host — minimum .env for `docker compose up`.
#
# Copy this file to `.env` at the repo root, fill in the required values,
# then run `docker compose up -d --build`. The values below are what the
# top-level docker-compose.yml expects; apps/api/.env.example has the full
# list of every env var the API consumes.

# ──────────────────────────────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────────────────────────────

# 64-char hex (`openssl rand -hex 32`). Encrypts OAuth tokens at rest.
# Production refuses to start without a real key.
RUNSTAMP_TOKEN_ENC_KEY=

# 32-char hex (`openssl rand -hex 16`). Salts hashed IPs for the waitlist.
RUNSTAMP_WAITLIST_IP_SALT=

# Your Firebase project id. Required to verify mobile auth tokens.
FIREBASE_PROJECT_ID=

# Local path to your Firebase service-account JSON. Default:
# ./secrets/firebase-service-account.json (which is gitignored).
FIREBASE_CREDENTIALS_HOST_PATH=./secrets/firebase-service-account.json

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL
# ──────────────────────────────────────────────────────────────────────

# Strava — only needed if you want Strava connectivity.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Public base URL the API serves under (used for OAuth redirects + emails).
# For local dev, leave the default. For production, set to your domain.
RUNSTAMP_PUBLIC_BASE_URL=http://localhost:8090

# Postgres credentials. Defaults are fine for local dev; change for prod.
POSTGRES_USER=runstamp
POSTGRES_PASSWORD=runstamp
POSTGRES_DB=runstamp

# CORS — comma-separated origins. Default allows the runstamp:// deep-link
# scheme used by the mobile app.
RUNSTAMP_ALLOWED_ORIGINS=runstamp://*

# Where the API binds on the host. Container port stays 8080.
RUNSTAMP_API_HOST_PORT=8090

# Build tag baked into the API image at compile time.
RUNSTAMP_VERSION=dev
