node_modules
.pnpm-store
.turbo
.expo
.astro
dist
build
out
.playwright-mcp
*.log
.DS_Store
.env
.env.*
!.env.example

# Server-side Firebase Admin service account — genuine secret, never commit.
apps/api/secrets/
firebase-service-account*.json

# EAS local credentials — Android keystore + iOS dist cert. Real signing
# secrets; anyone with these can sign apps as you. EAS docs explicitly say
# to gitignore these when using local credentials mode.
apps/mobile/credentials.json
apps/mobile/credentials/

# Generated native projects — Expo prebuild output, regenerable.
apps/mobile/ios
apps/mobile/android

# NOTE: GoogleService-Info.plist + google-services.json are intentionally
# NOT gitignored. Google's own docs confirm those config files are not
# secrets — the API key in them is the *public* Firebase Web API key
# and is restricted by bundle ID + Firebase Security Rules. Keeping them
# in the repo simplifies onboarding new devs and CI. The actual secrets
# (Firebase Admin service-account JSON, Strava client SECRET) stay on the
# server side only — see apps/api/.env.example.

ios/Pods
ios/build
android/.gradle
android/build
android/app/build
android/app/release
design.bin

# EAS local-build artifacts — large signed binaries; uploaded via
# `eas submit` directly.
apps/mobile/*.ipa
apps/mobile/*.aab
apps/mobile/*.apk

# Editor folders
.idea/
.vscode/
.cursor/

# TypeScript build info
*.tsbuildinfo

# Test + screenshot debris at repo root (Playwright captures, preview pages,
# scratch scripts). Keep `apps/**/assets/*.png` etc. unaffected.
/*.png
/*.jpg
/preview.html
/fix_comments.mjs
/generate_stamp_components.mjs

# Internal planning docs — kept locally for the maintainer, NOT shipped to
# the public repo. The PRD, roadmap, work logs, internal design specs, and
# Claude-session chat exports stay private. Public-facing pieces of the
# design system live in .impeccable.md (kept in the repo on purpose).
/runstamp-prd.md
/ROADMAP.md
/TONIGHT.md
/STRAVA_QUOTA.md
/docs/
/design/helios-run/chats/
